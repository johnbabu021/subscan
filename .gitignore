# ── Env files ─────────────────────────────────────────────────────────────────
.env
.env.local
.env*.local
frontend/.env
frontend/.env.local
frontend/.env*.local
backend/.env

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
*.pem

# ── Debug logs ────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
node_modules
.next